# =============================================================================
# Local AI Platform — Environment
# =============================================================================
# Single source of truth for all service URLs and ports.
# Add new services here as you build them.
#
# Native services (running directly on macOS):
#   Access from Mac:       http://localhost:<port>
#   Access from container: http://192.168.64.1:<port>
# =============================================================================

# --- LLM Server (native) -----------------------------------------------------
# LLM_MODE: "local" (default, uses mlx-lm on Apple Silicon)
#           "remote" (proxy to any OpenAI-compatible API)
LLM_MODE=local
LLM_SERVER_PORT=8000
LLM_SERVER_URL=http://192.168.64.1:8000
LLM_MODEL=mlx-community/Qwen3-8B-4bit

MAX_QUEUE_SIZE=20
MAX_TOKENS=8192

# --- Remote LLM (used when LLM_MODE=remote) ----------------------------------
# LLM_REMOTE_PROVIDER: "openai" (default) or "anthropic"
#
# Anthropic (Claude):
#   LLM_REMOTE_PROVIDER=anthropic
#   LLM_REMOTE_MODEL=claude-sonnet-4-6
#   LLM_REMOTE_BASE_URL is auto-set, leave empty
#
# OpenAI-compatible (OpenRouter, Together, Groq, etc.):
#   LLM_REMOTE_PROVIDER=openai
#   LLM_REMOTE_BASE_URL=https://openrouter.ai/api/v1
#   LLM_REMOTE_MODEL=meta-llama/llama-3.1-8b-instruct
LLM_REMOTE_PROVIDER=anthropic
LLM_REMOTE_BASE_URL=
LLM_REMOTE_API_KEY=
LLM_REMOTE_MODEL=claude-sonnet-4-6

# --- Chat App (container) ----------------------------------------------------
CHAT_APP_PORT=8001
CHAT_APP_URL=http://localhost:8001

# --- Code container (container) ----------------------------------------------
CODE_CONTAINER_PORT=8002
CODE_CONTAINER_URL=http://192.168.64.1:8002

# --- Postgres ----------------------------------------------
POSTGRES_PORT=5432
POSTGRES_DB=localai
POSTGRES_USER=localai
POSTGRES_PASSWORD=localai
# From Mac:       postgresql://localai:localai@localhost:5432/localai
# From container: postgresql://localai:localai@192.168.64.1:5432/localai
DATABASE_URL=postgresql://localai:localai@192.168.64.1:5432/localai

# --- Search service (container) ----------------------------------------------
SEARCH_APP_PORT=8003
SEARCH_APP_URL=http://192.168.64.1:8003

# --- SearXNG (container) -----------------------------------------------------
SEARXNG_PORT=8080
SEARXNG_URL=http://192.168.64.1:8080

# --- Files service (container) -----------------------------------------------
FILES_PORT=9000
FILES_URL=http://localhost:9000
FILES_ROOT=/data/files
# Full at-rest encryption (required). Encrypts file contents and filenames on disk.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Use a different key per deployment for data isolation.
FILES_ENCRYPTION_KEY=
