<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
    "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        keychain-access-groups is a RESTRICTED entitlement on macOS.
        It requires a real Apple Developer certificate (not ad-hoc signing).
        Ad-hoc signing with this entitlement will cause macOS to SIGKILL the binary.

        To use persistent Secure Enclave keys:
          1. Enroll in the Apple Developer Program ($99/year).
          2. Create an App ID with Keychain Sharing enabled in the developer portal.
          3. Replace the placeholder below with: <TeamID>.com.example.keychain-rs
          4. Sign with your Developer ID:
               codesign --entitlements entitlements/keychain-rs.entitlements \
                        --sign "Developer ID Application: Your Name (TEAMID)" \
                        target/debug/keychain-rs

        For EPHEMERAL (non-persistent) Secure Enclave keys no entitlement is needed
        and they work with plain `cargo run`.  The demo falls back to ephemeral
        automatically when the persistent path fails.
    -->
    <key>keychain-access-groups</key>
    <array>
        <string>YOURTEAMID.com.example.keychain-rs</string>
    </array>

    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
